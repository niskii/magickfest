{
    "$schema": "https://json.schemastore.org/tsconfig",
    "_version": "25.0.0",

    "compilerOptions": {
        "lib": [
            "es2024",
            "ESNext.Array",
            "ESNext.Collection",
            "ESNext.Iterator",
            "ESNext.Promise"
        ],
        "module": "nodenext",
        "target": "es2024",
        "types": ["node"],
        "strict": true,
        "sourceMap": true,
        "esModuleInterop": true,
        "allowJs": true,
        "skipLibCheck": true,
        "moduleResolution": "node16",
        "paths": {
            "@shared/*": ["../shared/*"],
            "*": ["./*"]
        },

        // "rootDir": "..",
        "outDir": "./dist",
        "rootDir": ".."
    },
    "include": [
        "**/*.ts",
        "src/bot/deleteCommands.js.js",
        "src/bot/deleteCommand.js",
        "tools/deleteCommands.js",
        "srtools/registerCommands.js"
    ],
    "exclude": ["dist"]
}
